	fi
	
	# Update summary to include the POST test
	if [ "$COMMENT_SUBMISSION_TEST" = true ] && [ "$COMMENT_STORAGE_TEST" = true ] && [ "$COMMENT_ADMIN_TEST" = true ] && [ "$COMMENT_EXPANSION_TEST" = true ] && [ "$COMMENT_PROCESS_TEST" = true ]; then
