		echo "DEBUG: - Comment storage: ✅"
		echo "DEBUG: - Comment admin panel: ✅"
		echo "DEBUG: - Comment form expansion: ✅"
		echo "DEBUG: - Process Selected Comments POST: ✅"
	else
		echo "DEBUG: === UPDATED COMMENT SYSTEM TEST SUMMARY ==="
		echo "DEBUG: ⚠️  SOME COMMENT TESTS FAILED"
		echo "DEBUG: - Comment submission via cgi-bin: $COMMENT_SUBMISSION_TEST"
		echo "DEBUG: - Comment storage: $COMMENT_STORAGE_TEST"
		echo "DEBUG: - Comment admin panel: $COMMENT_ADMIN_TEST"
		echo "DEBUG: - Comment form expansion: $COMMENT_EXPANSION_TEST"
		echo "DEBUG: - Process Selected Comments POST: $COMMENT_PROCESS_TEST"
		tail_server_log
	fi
	
	echo === END COMMENT SYSTEM TESTS ===
	
	# Test stats panel functionality
	echo "DEBUG: Testing stats panel functionality..."
	echo === STATS PANEL TEST ===
	
	# Test 1: Check if stats extension is available via admin URLs
	echo "DEBUG: Test 1 - Checking if stats extension is available via admin URLs..."
	STATS_ADMIN_URL=$(echo "$ADMIN_URLS" | grep "stats_" | head -1)
	if [ -n "$STATS_ADMIN_URL" ]; then
		echo "DEBUG: ✅ SUCCESS - Stats admin URL found: $STATS_ADMIN_URL"
		STATS_URL_TEST=true
		
		# Test 2: Test stats panel access
		echo "DEBUG: Test 2 - Testing stats panel access..."
		FULL_STATS_URL="https://$SRV$STATS_ADMIN_URL"
		echo "DEBUG: Testing stats panel at: $FULL_STATS_URL"
		
		# Test with curl -I to check headers
		if curl -I -k --connect-timeout 10 --max-time 30 "$FULL_STATS_URL" 2>/dev/null | grep -q "200 OK"; then
			echo "DEBUG: ✅ SUCCESS - Stats panel returns 200 OK"
			STATS_ACCESS_TEST=true
		else
			echo "DEBUG: ❌ FAILED - Stats panel does not return 200 OK"
			echo "DEBUG: Response headers from stats panel:"
			curl -I -k --connect-timeout 10 --max-time 30 "$FULL_STATS_URL" 2>&1 | head -10
			STATS_ACCESS_TEST=false
		fi
		
		# Test 3: Test stats panel content
		echo "DEBUG: Test 3 - Testing stats panel content..."
		if curl -s -k --connect-timeout 10 --max-time 30 "$FULL_STATS_URL" | grep -q "System Statistics\|Memory Usage\|CPU Usage"; then
			echo "DEBUG: ✅ SUCCESS - Stats panel contains expected content"
			STATS_CONTENT_TEST=true
		else
			echo "DEBUG: ❌ FAILED - Stats panel does not contain expected content"
			echo "DEBUG: Response content from stats panel:"
			curl -s -k --connect-timeout 10 --max-time 30 "$FULL_STATS_URL" | head -20
			STATS_CONTENT_TEST=false
		fi
		
		# Test 4: Test specific stats panel URL mentioned in issue
		echo "DEBUG: Test 4 - Testing specific stats panel URL from issue..."
		SPECIFIC_STATS_URL="https://ca2.dansted.org/stats_5bc213dae0a4c555"
		if curl -I -k --connect-timeout 10 --max-time 30 "$SPECIFIC_STATS_URL" 2>/dev/null | grep -q "200 OK"; then
			echo "DEBUG: ✅ SUCCESS - Specific stats panel URL returns 200 OK"
			SPECIFIC_STATS_TEST=true
		else
			echo "DEBUG: ❌ FAILED - Specific stats panel URL does not return 200 OK"
			echo "DEBUG: Response from specific stats URL:"
			curl -I -k --connect-timeout 10 --max-time 30 "$SPECIFIC_STATS_URL" 2>&1 | head -10
			SPECIFIC_STATS_TEST=false
		fi
		
	else
		echo "DEBUG: ❌ FAILED - Could not find stats admin URL"
		STATS_URL_TEST=false
		STATS_ACCESS_TEST=false
		STATS_CONTENT_TEST=false
		SPECIFIC_STATS_TEST=false
	fi
	
	# Summary
	echo "DEBUG: === STATS PANEL TEST SUMMARY ==="
	if [ "$STATS_URL_TEST" = true ] && [ "$STATS_ACCESS_TEST" = true ] && [ "$STATS_CONTENT_TEST" = true ] && [ "$SPECIFIC_STATS_TEST" = true ]; then
		echo "DEBUG: 🎉 ALL STATS PANEL TESTS PASSED - Stats panel is working correctly"
		echo "DEBUG: - Stats admin URL found: ✅"
		echo "DEBUG: - Stats panel access (200 OK): ✅"
		echo "DEBUG: - Stats panel content: ✅"
		echo "DEBUG: - Specific stats URL: ✅"
	else
		echo "DEBUG: ⚠️  SOME STATS PANEL TESTS FAILED"
		echo "DEBUG: - Stats admin URL found: $STATS_URL_TEST"
		echo "DEBUG: - Stats panel access (200 OK): $STATS_ACCESS_TEST"
		echo "DEBUG: - Stats panel content: $STATS_CONTENT_TEST"
		echo "DEBUG: - Specific stats URL: $SPECIFIC_STATS_TEST"
		tail_server_log
	fi
	
	echo === END STATS PANEL TESTS ===
	
	# Test file upload functionality
	echo "DEBUG: Testing file upload functionality..."
	echo === FILE UPLOAD TEST ===
	
	# Get the upload admin URL
	echo "DEBUG: Test 1 - Finding upload admin URL..."
	UPLOAD_ADMIN_PATH=$(echo "$ADMIN_URLS" | grep -o "upload_[a-f0-9]*" | head -1)
	if [ -z "$UPLOAD_ADMIN_PATH" ]; then
		echo "DEBUG: ❌ FAILED - Could not find upload admin URL"
		UPLOAD_URL_TEST=false
	else
		UPLOAD_ADMIN_URL="/$UPLOAD_ADMIN_PATH"
		echo "DEBUG: ✅ SUCCESS - Upload admin URL found: $UPLOAD_ADMIN_URL"
		UPLOAD_URL_TEST=true
		
		# Test 2: Test upload panel access
		echo "DEBUG: Test 2 - Testing upload panel access..."
		FULL_UPLOAD_URL="https://$SRV$UPLOAD_ADMIN_URL"
		if curl -k --connect-timeout 10 --max-time 30 "$FULL_UPLOAD_URL" 2>/dev/null | grep -q "File Upload Manager"; then
			echo "DEBUG: ✅ SUCCESS - Upload panel accessible"
			UPLOAD_ACCESS_TEST=true
		else
			echo "DEBUG: ❌ FAILED - Upload panel not accessible"
			curl -k --connect-timeout 10 --max-time 30 "$FULL_UPLOAD_URL" 2>&1 | head -10
			UPLOAD_ACCESS_TEST=false
		fi
		
		# Test 3: Test file upload via curl
		echo "DEBUG: Test 3 - Testing file upload via curl..."
		TEST_FILE="test_upload_file.txt"
		echo "This is a test file for upload testing. $(date)" > "$TEST_FILE"
		
		if curl -k --connect-timeout 10 --max-time 30 \
			-F "file=@$TEST_FILE" \
			"$FULL_UPLOAD_URL" | grep -q "Upload Successful"; then
			echo "DEBUG: ✅ SUCCESS - File upload succeeded"
			UPLOAD_SUBMIT_TEST=true
		else
			echo "DEBUG: ❌ FAILED - File upload failed"
			curl -k --connect-timeout 10 --max-time 30 \
				-F "file=@$TEST_FILE" \
				"$FULL_UPLOAD_URL" | head -20
			UPLOAD_SUBMIT_TEST=false
		fi
		
		# Test 4: Check if file was actually saved
		echo "DEBUG: Test 4 - Checking if uploaded file was saved..."
		if ssh root@$SRV "test -f /var/www/html/uploads/$TEST_FILE"; then
			echo "DEBUG: ✅ SUCCESS - File was saved to uploads directory"
			UPLOAD_SAVE_TEST=true
			
			# Test 5: Check file contents
			echo "DEBUG: Test 5 - Checking file contents..."
			if ssh root@$SRV "grep -q 'test file for upload testing' /var/www/html/uploads/$TEST_FILE"; then
				echo "DEBUG: ✅ SUCCESS - File contents are correct"
				UPLOAD_CONTENT_TEST=true
			else
				echo "DEBUG: ❌ FAILED - File contents are incorrect"
				UPLOAD_CONTENT_TEST=false
			fi
		else
			echo "DEBUG: ❌ FAILED - File was not saved to uploads directory"
			UPLOAD_SAVE_TEST=false
			UPLOAD_CONTENT_TEST=false
		fi
		
		# Test 6: List uploaded files
		echo "DEBUG: Test 6 - Testing file listing..."
		if curl -s -k --connect-timeout 10 --max-time 30 "$FULL_UPLOAD_URL" | grep -q "$TEST_FILE"; then
			echo "DEBUG: ✅ SUCCESS - Uploaded file appears in file list"
			UPLOAD_LIST_TEST=true
		else
			echo "DEBUG: ❌ FAILED - Uploaded file does not appear in file list"
			UPLOAD_LIST_TEST=false
		fi
		
		# Cleanup
		rm -f "$TEST_FILE"
		ssh root@$SRV "rm -f /var/www/html/uploads/$TEST_FILE" || true
	fi
	
	# Summary
	echo "DEBUG: === FILE UPLOAD TEST SUMMARY ==="
	if [ "$UPLOAD_URL_TEST" = true ] && [ "$UPLOAD_ACCESS_TEST" = true ] && [ "$UPLOAD_SUBMIT_TEST" = true ] && [ "$UPLOAD_SAVE_TEST" = true ] && [ "$UPLOAD_CONTENT_TEST" = true ] && [ "$UPLOAD_LIST_TEST" = true ]; then
		echo "DEBUG: 🎉 ALL FILE UPLOAD TESTS PASSED - File upload functionality is working correctly"
		echo "DEBUG: - Upload admin URL found: ✅"
		echo "DEBUG: - Upload panel access (200 OK): ✅"
		echo "DEBUG: - File upload submission: ✅"
		echo "DEBUG: - File saved to disk: ✅"
		echo "DEBUG: - File contents correct: ✅"
		echo "DEBUG: - File listed in manager: ✅"
	else
		echo "DEBUG: ⚠️  SOME FILE UPLOAD TESTS FAILED"
		echo "DEBUG: - Upload admin URL found: $UPLOAD_URL_TEST"
		echo "DEBUG: - Upload panel access: $UPLOAD_ACCESS_TEST"
		echo "DEBUG: - File upload submission: $UPLOAD_SUBMIT_TEST"
		echo "DEBUG: - File saved to disk: $UPLOAD_SAVE_TEST"
		echo "DEBUG: - File contents correct: $UPLOAD_CONTENT_TEST"
		echo "DEBUG: - File listed in manager: $UPLOAD_LIST_TEST"
		tail_server_log
	fi
	
	echo === END FILE UPLOAD TESTS ===
	
	if [ -z "$KEEPALIVE" ]
	then
		ssh root@$SRV "pkill easyp; sleep 1; pkill -9 easyp" || echo "DEBUG: Server process cleanup completed"
		echo "DEBUG: Stopping server process on remote server..."
	fi
	
	echo "DEBUG: Test script completed"
        
fi

echo Finished at: `date`
